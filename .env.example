# ============================================================
# 시시콜콜 환경변수 예시
# 이 파일을 복사해 .env 를 만들고 본인 값으로 채우세요.
# .env 는 절대 커밋하지 마세요.
#
# 원칙:
# - 실제 API Key / Token / OAuth Secret / Password는 .env에만 넣습니다.
# - .env.example에는 더미 값만 둡니다.
# - 기본 개발 모드는 mock-first 입니다.
# - 실제 외부 서비스 실행은 *_REAL=true 로 켭니다.
# ============================================================


# ============================================================
# App
# ============================================================

ENV=development
LOG_LEVEL=INFO

# FastAPI / ngrok base URL
# 예: https://xxxx-xxx-xxx.ngrok-free.app
BASE_URL=https://your-ngrok-url.ngrok-free.app

# Admin Auth / JWT
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60


# ============================================================
# Twilio
# ============================================================
# Twilio Console > Account Info 에서 확인

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+821012345678

# Zoiper / SIP 테스트를 쓰는 경우
TWILIO_SIP_DOMAIN=your-sip-domain.sip.twilio.com


# ============================================================
# OpenAI / Post-call LLM
# ============================================================

OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Preferred Post-call LLM switch.
# mock: deterministic local mock, no OpenAI call
# real: OpenAI call for transcript-grounded post-call analysis
POST_CALL_LLM_MODE=mock
POST_CALL_LLM_MODEL=gpt-4o-mini

# Post-call Summary/VOC/Priority에서 실제 OpenAI 호출 여부
# false: Mock LLM 사용
# true : 실제 OpenAI Provider 사용
# Deprecated compatibility flag. Prefer POST_CALL_LLM_MODE=real.
POST_CALL_USE_REAL_LLM=false


# ============================================================
# Deepgram STT
# ============================================================

DEEPGRAM_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ============================================================
# Google Cloud TTS
# ============================================================
# Google Cloud 서비스 계정 JSON 파일 경로
# 예: C:\kdy\secrets\google-tts-service-account.json

GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json


# ============================================================
# PostgreSQL
# ============================================================

POSTGRES_USER=sisicallcall
POSTGRES_PASSWORD=changeme
POSTGRES_DB=sisicallcall
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DATABASE_URL=postgresql://sisicallcall:changeme@localhost:5432/sisicallcall


# ============================================================
# Redis
# ============================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379


# ============================================================
# ChromaDB
# ============================================================

CHROMA_HOST=localhost
CHROMA_PORT=8001


# ============================================================
# Post-call MCP 공통 정책
# ============================================================
# 기본값은 mock-first.
# 실제 Jira / Calendar / Gmail / Slack / Company DB 실행을 보려면
# 각 서비스별 *_REAL 값을 true로 바꾸고 필요한 인증정보를 채워야 합니다.
#
# status 정책:
# - *_REAL=false  → mock success
# - *_REAL=true + 설정 부족 → skipped 또는 failed
# - *_REAL=true + 실제 connector 구현 완료 + 설정 정상 → 실제 외부 서비스 호출
# ============================================================


# ============================================================
# Gmail MCP / Gmail 실제 메일 발송
# ============================================================
# 용도:
# - Post-call 후 관리자에게 상담 요약/긴급 VOC 메일 발송
#
# 필요한 준비:
# - Google Cloud Console에서 Gmail API 활성화
# - OAuth Client credentials.json 다운로드
# - 최초 로그인 후 token.json 생성
#
# 필요 scope:
# - https://www.googleapis.com/auth/gmail.send
# ============================================================

GMAIL_MCP_REAL=false

# 관리자 수신 이메일
GMAIL_MANAGER_TO=manager@example.com

# 발신 계정
GMAIL_SENDER=your-email@gmail.com

# OAuth credentials/token 경로
GOOGLE_GMAIL_CREDENTIALS_PATH=C:\kdy\secrets\gmail_credentials.json
GOOGLE_GMAIL_TOKEN_PATH=C:\kdy\secrets\gmail_token.json

# 별도 Gmail MCP 서버를 띄우는 경우에만 사용
GMAIL_MCP_SERVER_URL=


# ============================================================
# Google Calendar MCP / Calendar 실제 일정 생성
# ============================================================
# 용도:
# - 고객 콜백 일정 생성
# - 상담 예약/후속 확인 일정 생성
#
# 필요한 준비:
# - Google Cloud Console에서 Google Calendar API 활성화
# - OAuth Client credentials.json 다운로드
# - 최초 로그인 후 token.json 생성
#
# 필요 scope:
# - https://www.googleapis.com/auth/calendar.events
# ============================================================

CALENDAR_MCP_REAL=false

# 기본 담당자 / 캘린더 소유자
CALENDAR_DEFAULT_OWNER=your-email@gmail.com

# 콜백 일정 기본 길이
CALENDAR_DEFAULT_DURATION_MIN=30

# primary 또는 특정 calendar_id
GOOGLE_CALENDAR_ID=primary

# OAuth credentials/token 경로
GOOGLE_CALENDAR_CREDENTIALS_PATH=C:\kdy\secrets\calendar_credentials.json
GOOGLE_CALENDAR_TOKEN_PATH=C:\kdy\secrets\calendar_token.json

# 별도 Calendar MCP 서버를 띄우는 경우에만 사용
CALENDAR_MCP_SERVER_URL=


# ============================================================
# Jira MCP / Jira 실제 이슈 생성
# ============================================================
# 용도:
# - VOC 이슈 생성
# - 반복 민원 / 장애 의심 / FAQ 개선 요청 등록
#
# 필요한 준비:
# - Jira Cloud 사이트 URL
# - Atlassian 로그인 이메일
# - Atlassian API Token
# - Project Key
# - Issue Type
# ============================================================

JIRA_MCP_REAL=false

# 예: https://ofcalls.atlassian.net
JIRA_BASE_URL=https://your-domain.atlassian.net

# Atlassian 로그인 이메일
JIRA_EMAIL=your-email@example.com

# Atlassian API Token
JIRA_API_TOKEN=your_atlassian_api_token

# Jira 프로젝트 키
JIRA_PROJECT_KEY=KDT

# 예: Task / Bug / Story
JIRA_ISSUE_TYPE=Task

# VOC 이슈 라벨
JIRA_VOC_LABEL=post-call-voc

# 별도 Jira MCP 서버를 띄우는 경우에만 사용
JIRA_MCP_SERVER_URL=


# ============================================================
# Slack MCP / Slack 실제 알림
# ============================================================
# 용도:
# - critical VOC
# - angry + escalated
# - 장애/오류 의심
# - 긴급 관리자 알림
#
# 필요한 준비:
# - Slack App 생성
# - Bot Token Scopes 설정
# - Workspace에 앱 설치
# - Bot User OAuth Token 확인
# - 알림 채널에 Bot 초대
#
# 필요 scope 예시:
# - chat:write
# - channels:read
# - groups:read  # private channel 사용 시
# ============================================================

SLACK_MCP_REAL=false

# Slack Bot Token
SLACK_BOT_TOKEN=xoxb-your-token

# 채널명 또는 channel_id
SLACK_ALERT_CHANNEL=#voc-alerts
SLACK_CRITICAL_CHANNEL=#urgent-cs

# 별도 Slack MCP 서버를 띄우는 경우에만 사용
SLACK_MCP_SERVER_URL=


# ============================================================
# Company DB MCP / 임시 회사 DB 실제 반영
# ============================================================
# 용도:
# - VOC 이슈 내부 DB 저장
# - 우선순위 큐 반영
# - 예약/접수/후속 처리 기록
#
# 방식:
# 1. 자체 API 호출
# 2. 별도 Company DB MCP 서버 호출
# 3. DB 직접 연결
# ============================================================

MCP_COMPANY_DB_REAL=false
COMPANY_DB_MCP_REAL=false

# 자체 API 방식
COMPANY_DB_BASE_URL=http://localhost:8010
COMPANY_DB_INTERNAL_TOKEN=dev-token

# 별도 Company DB MCP 서버 방식
COMPANY_DB_MCP_SERVER_URL=http://localhost:9005

# DB 직접 연결 방식이 필요한 경우
COMPANY_DB_HOST=localhost
COMPANY_DB_PORT=5432
COMPANY_DB_NAME=company_demo
COMPANY_DB_USER=postgres
COMPANY_DB_PASSWORD=changeme


# ============================================================
# Post-call Action / Dashboard
# ============================================================

# critical priority 발생 시 Slack 알림을 만들지 여부
POST_CALL_ENABLE_SLACK_ON_CRITICAL=true

# angry + escalated 발생 시 관리자 메일 생성 여부
POST_CALL_ENABLE_MANAGER_EMAIL_ON_ESCALATION=true

# repeated issue / FAQ candidate 발생 시 Jira issue 생성 여부
POST_CALL_ENABLE_JIRA_FOR_REPEAT_TOPIC=true

# 콜백 필요 시 Calendar action 생성 여부
POST_CALL_ENABLE_CALENDAR_CALLBACK=true


# ============================================================
# Speaker Verification / Barge-in
# ============================================================
# 팀원별 GPU/NeMo 환경이 다를 수 있으므로 기본값은 false.
# 실제 통화 중 화자검증을 켤 때만 true.

BARGEIN_VERIFY_ENABLED=false

# 사용할 speaker verification 구현체
# 예: ecapa / titanet / mock
SPEAKER_VERIFY_PROVIDER=ecapa

# 초기 placeholder 값. 실제 threshold는 실험 결과로 조정.
SPEAKER_VERIFY_THRESHOLD=0.70


# ============================================================
# RAG / Chroma 정책
# ============================================================
# 후처리 테스트에서는 Chroma가 필요하지 않음.
# 실시간 FAQ/RAG 전체 통화 테스트 시에만 필요.

CHROMA_REQUIRED=false
RAG_FAIL_SOFT=true


# ============================================================
# Local development flags
# ============================================================

DEBUG=true
TESTING=false
